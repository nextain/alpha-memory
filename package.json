{
	"name": "@nextain/alpha-memory",
	"version": "0.1.4",
	"description": "Alpha Memory System — Naia OS cognitive memory architecture",
	"type": "module",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/nextain/alpha-memory.git"
	},
	"keywords": [
		"memory",
		"ai",
		"naia",
		"vector-search",
		"knowledge-graph",
		"llm-memory"
	],
	"exports": {
		".": {
			"import": "./dist/memory/index.js",
			"types": "./dist/memory/index.d.ts"
		}
	},
	"types": "./dist/memory/index.d.ts",
	"files": [
		"dist/memory/",
		"dist/utils/",
		"src/memory/",
		"src/utils/",
		"README.md",
		"README.ko.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
