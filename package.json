		"@vitest/coverage-v8": "^4.1.5",
		"mem0ai": "^2.4.2",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vectra": "^0.2.2",
		"vitest": "^4.0.18"
	},
	"engines": {
		"node": ">=20"
	}
